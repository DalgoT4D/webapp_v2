NEXT_PUBLIC_WEBAPP_ENVIRONMENT= #"staging" #or "production"

NEXT_PUBLIC_BACKEND_URL=
NEXT_PUBLIC_USAGE_DASHBOARD_ID=
NEXT_PUBLIC_USAGE_DASHBOARD_DOMAIN=

# Airbyte UI URL (for clickable Workspace ID link — super admins only)
NEXT_PUBLIC_AIRBYTE_URL=

# Pipeline/Orchestrate
NEXT_PUBLIC_ENABLE_LOG_SUMMARIES=true

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source map uploads — generate in Sentry Settings → Auth Tokens
# Required in CI/CD for readable stack traces in production
SENTRY_AUTH_TOKEN=

# E2E Testing (Playwright)
# Set these to run E2E tests that require authentication
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
# Optional: Override base URL to test against staging/production (defaults to localhost:3001)
E2E_BASE_URL=